# ============================================
# AutoFlow Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ============================================
# CORE SETTINGS (Required for basic operation)
# ============================================

# Environment: development, staging, production, test
# Required: Yes (defaults to development)
AUTOFLOW_ENVIRONMENT=development

# Enable/disable AutoFlow engine
# Required: No (defaults to true)
AUTOFLOW_ENABLED=true

# Workspace directory for AutoFlow files
# Required: No (defaults to ./autoflow_workspace)
AUTOFLOW_WORKSPACE=./autoflow_workspace

# Workflow identifier for tracking
# Required: No (defaults to "default")
AUTOFLOW_WORKFLOW_ID=default

# Enable debug mode (verbose logging)
# Required: No (defaults to false)
AUTOFLOW_DEBUG=false

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Database type: sqlite, postgresql, mysql, redis, mongodb, clickhouse
# Required: No (defaults to sqlite)
AUTOFLOW_DB_TYPE=sqlite

# --- SQLite Settings (Default) ---

# SQLite database path (:memory: for in-memory)
# Required: If using sqlite (defaults to ./autoflow.db)
AUTOFLOW_DB_PATH=./autoflow.db

# --- PostgreSQL Settings ---

# PostgreSQL host
# Required: If db_type=postgresql
# AUTOFLOW_POSTGRES_HOST=localhost

# PostgreSQL port
# Required: No (defaults to 5432)
# AUTOFLOW_POSTGRES_PORT=5432

# PostgreSQL database name
# Required: If db_type=postgresql
# AUTOFLOW_POSTGRES_DATABASE=autoflow

# PostgreSQL user
# Required: If db_type=postgresql
# AUTOFLOW_POSTGRES_USER=autoflow_user

# PostgreSQL password
# Required: If db_type=postgresql
# AUTOFLOW_POSTGRES_PASSWORD=your-password-here

# Connection pool size
# Required: No (defaults to 10)
# AUTOFLOW_POSTGRES_POOL_SIZE=10

# Max overflow for pool
# Required: No (defaults to 20)
# AUTOFLOW_POSTGRES_MAX_OVERFLOW=20

# Enable SSL/TLS
# Required: No (defaults to false)
# AUTOFLOW_POSTGRES_SSL=false

# SSL mode: disable, allow, prefer, require, verify-ca, verify-full
# Required: No (defaults to prefer)
# AUTOFLOW_POSTGRES_SSL_MODE=prefer

# Connection timeout in seconds
# Required: No (defaults to 30)
# AUTOFLOW_POSTGRES_TIMEOUT=30

# --- MySQL/MariaDB Settings ---

# MySQL host
# Required: If db_type=mysql
# AUTOFLOW_MYSQL_HOST=localhost

# MySQL port
# Required: No (defaults to 3306)
# AUTOFLOW_MYSQL_PORT=3306

# MySQL database name
# Required: If db_type=mysql
# AUTOFLOW_MYSQL_DATABASE=autoflow

# MySQL user
# Required: If db_type=mysql
# AUTOFLOW_MYSQL_USER=autoflow_user

# MySQL password
# Required: If db_type=mysql
# AUTOFLOW_MYSQL_PASSWORD=your-password-here

# Connection pool size
# Required: No (defaults to 10)
# AUTOFLOW_MYSQL_POOL_SIZE=10

# Enable SSL
# Required: No (defaults to false)
# AUTOFLOW_MYSQL_SSL=false

# --- Redis Settings ---

# Redis host
# Required: If db_type=redis or using Redis features
# AUTOFLOW_REDIS_HOST=localhost

# Redis port
# Required: No (defaults to 6379)
# AUTOFLOW_REDIS_PORT=6379

# Redis database number (0-15)
# Required: No (defaults to 0)
# AUTOFLOW_REDIS_DB=0

# Redis password
# Required: No (defaults to None)
# AUTOFLOW_REDIS_PASSWORD=your-redis-password

# Enable SSL/TLS
# Required: No (defaults to false)
# AUTOFLOW_REDIS_SSL=false

# Connection pool size
# Required: No (defaults to 10)
# AUTOFLOW_REDIS_POOL_SIZE=10

# --- MongoDB Settings ---

# MongoDB host
# Required: If db_type=mongodb
# AUTOFLOW_MONGODB_HOST=localhost

# MongoDB port
# Required: No (defaults to 27017)
# AUTOFLOW_MONGODB_PORT=27017

# MongoDB database name
# Required: If db_type=mongodb
# AUTOFLOW_MONGODB_DATABASE=autoflow

# MongoDB user
# Required: No (defaults to None)
# AUTOFLOW_MONGODB_USER=autoflow_user

# MongoDB password
# Required: No (defaults to None)
# AUTOFLOW_MONGODB_PASSWORD=your-password-here

# Enable authentication
# Required: No (defaults to false)
# AUTOFLOW_MONGODB_AUTH=false

# --- ClickHouse Settings ---

# ClickHouse host
# Required: If db_type=clickhouse
# AUTOFLOW_CLICKHOUSE_HOST=localhost

# ClickHouse port
# Required: No (defaults to 8123)
# AUTOFLOW_CLICKHOUSE_PORT=8123

# ClickHouse database name
# Required: If db_type=clickhouse
# AUTOFLOW_CLICKHOUSE_DATABASE=autoflow

# ClickHouse user
# Required: No (defaults to default)
# AUTOFLOW_CLICKHOUSE_USER=default

# ClickHouse password
# Required: No (defaults to empty string)
# AUTOFLOW_CLICKHOUSE_PASSWORD=

# ============================================
# VECTOR DATABASE CONFIGURATION
# ============================================

# Default embedding dimension
# Required: No (defaults to 1536 for OpenAI ada-002)
AUTOFLOW_EMBEDDING_DIMENSION=1536

# --- Pinecone Settings (Cloud Vector DB) ---

# Enable Pinecone
# Required: No (defaults to false)
# AUTOFLOW_PINECONE_ENABLED=false

# Pinecone API key
# Required: If pinecone_enabled=true
# AUTOFLOW_PINECONE_API_KEY=your-pinecone-api-key

# Pinecone environment (us-west1-gcp, us-east1-gcp, etc.)
# Required: If pinecone_enabled=true
# AUTOFLOW_PINECONE_ENVIRONMENT=us-west1-gcp

# Pinecone index name
# Required: If pinecone_enabled=true
# AUTOFLOW_PINECONE_INDEX=autoflow

# Index name prefix for multi-environment setups
# Required: No (defaults to empty string)
# AUTOFLOW_PINECONE_INDEX_PREFIX=

# Pinecone project ID
# Required: No (auto-detected from API key)
# AUTOFLOW_PINECONE_PROJECT_ID=

# --- ChromaDB Settings (Local Vector DB - Free) ---

# Enable ChromaDB
# Required: No (defaults to false)
# AUTOFLOW_CHROMADB_ENABLED=false

# ChromaDB persist directory
# Required: If chromadb_enabled=true (defaults to ./chroma_db)
# AUTOFLOW_CHROMADB_PATH=./chroma_db

# Collection name
# Required: No (defaults to "autoflow")
# AUTOFLOW_CHROMADB_COLLECTION=autoflow

# --- Weaviate Settings (Self-hosted Vector DB) ---

# Enable Weaviate
# Required: No (defaults to false)
# AUTOFLOW_WEAVIATE_ENABLED=false

# Weaviate URL
# Required: If weaviate_enabled=true
# AUTOFLOW_WEAVIATE_URL=http://localhost:8080

# API key (if authentication enabled)
# Required: No
# AUTOFLOW_WEAVIATE_API_KEY=your-weaviate-api-key

# --- Qdrant Settings (Self-hosted Vector DB) ---

# Enable Qdrant
# Required: No (defaults to false)
# AUTOFLOW_QDRANT_ENABLED=false

# Qdrant URL
# Required: If qdrant_enabled=true
# AUTOFLOW_QDRANT_URL=http://localhost:6333

# API key (if authentication enabled)
# Required: No
# AUTOFLOW_QDRANT_API_KEY=your-qdrant-api-key

# Collection name
# Required: No (defaults to "autoflow")
# AUTOFLOW_QDRANT_COLLECTION=autoflow

# --- Milvus Settings (Self-hosted Vector DB) ---

# Enable Milvus
# Required: No (defaults to false)
# AUTOFLOW_MILVUS_ENABLED=false

# Milvus host
# Required: If milvus_enabled=true
# AUTOFLOW_MILVUS_HOST=localhost

# Milvus port
# Required: No (defaults to 19530)
# AUTOFLOW_MILVUS_PORT=19530

# Collection name
# Required: No (defaults to "autoflow")
# AUTOFLOW_MILVUS_COLLECTION=autoflow

# Index type (IVF_FLAT, IVF_SQ8, HNSW, etc.)
# Required: No (defaults to IVF_FLAT)
# AUTOFLOW_MILVUS_INDEX_TYPE=IVF_FLAT

# --- Pgvector Settings (PostgreSQL Extension) ---

# Enable pgvector (requires PostgreSQL)
# Required: No (defaults to false)
# AUTOFLOW_PGVECTOR_ENABLED=false

# Table name
# Required: No (defaults to "autoflow_vectors")
# AUTOFLOW_PGVECTOR_TABLE=autoflow_vectors

# Column name for embeddings
# Required: No (defaults to "embedding")
# AUTOFLOW_PGVECTOR_COLUMN=embedding

# Distance metric (cosine, l2, ip)
# Required: No (defaults to cosine)
# AUTOFLOW_PGVECTOR_DISTANCE_METRIC=cosine

# ============================================
# MESSAGE QUEUE CONFIGURATION
# ============================================

# --- Kafka Settings ---

# Enable Kafka
# Required: No (defaults to false)
# AUTOFLOW_KAFKA_ENABLED=false

# Kafka bootstrap servers (comma-separated)
# Required: If kafka_enabled=true
# AUTOFLOW_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Topic prefix for AutoFlow topics
# Required: No (defaults to "autoflow")
# AUTOFLOW_KAFKA_TOPIC_PREFIX=autoflow

# Consumer group ID
# Required: No (defaults to "autoflow-consumer")
# AUTOFLOW_KAFKA_CONSUMER_GROUP=autoflow-consumer

# Auto commit offsets
# Required: No (defaults to true)
# AUTOFLOW_KAFKA_AUTO_COMMIT=true

# Auto offset reset (earliest, latest, none)
# Required: No (defaults to latest)
# AUTOFLOW_KAFKA_AUTO_OFFSET_RESET=latest

# Session timeout in milliseconds
# Required: No (defaults to 30000)
# AUTOFLOW_KAFKA_SESSION_TIMEOUT=30000

# --- RabbitMQ Settings ---

# Enable RabbitMQ
# Required: No (defaults to false)
# AUTOFLOW_RABBITMQ_ENABLED=false

# RabbitMQ URL (amqp:// or amqps://)
# Required: If rabbitmq_enabled=true
# AUTOFLOW_RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Exchange name
# Required: No (defaults to "autoflow")
# AUTOFLOW_RABBITMQ_EXCHANGE=autoflow

# Queue prefix
# Required: No (defaults to "autoflow")
# AUTOFLOW_RABBITMQ_QUEUE_PREFIX=autoflow

# Virtual host
# Required: No (defaults to "/")
# AUTOFLOW_RABBITMQ_VHOST=/

# --- AWS SQS Settings ---

# Enable SQS
# Required: No (defaults to false)
# AUTOFLOW_SQS_ENABLED=false

# AWS region
# Required: If sqs_enabled=true
# AUTOFLOW_SQS_REGION=us-east-1

# Queue name prefix
# Required: No (defaults to "autoflow")
# AUTOFLOW_SQS_QUEUE_PREFIX=autoflow

# AWS access key ID
# Required: No (can use IAM roles)
# AUTOFLOW_SQS_ACCESS_KEY_ID=

# AWS secret access key
# Required: No (can use IAM roles)
# AUTOFLOW_SQS_SECRET_ACCESS_KEY=

# --- Redis Streams Settings ---

# Enable Redis Streams
# Required: No (defaults to false)
# AUTOFLOW_REDIS_STREAMS_ENABLED=false

# Stream key prefix
# Required: No (defaults to "autoflow")
# AUTOFLOW_REDIS_STREAMS_PREFIX=autoflow

# Consumer group name
# Required: No (defaults to "autoflow-consumer")
# AUTOFLOW_REDIS_STREAMS_CONSUMER_GROUP=autoflow-consumer

# ============================================
# CLOUD STORAGE CONFIGURATION
# ============================================

# --- AWS S3 Settings ---

# Enable S3
# Required: No (defaults to false)
# AUTOFLOW_S3_ENABLED=false

# S3 bucket name
# Required: If s3_enabled=true
# AUTOFLOW_S3_BUCKET=autoflow-bucket

# AWS region
# Required: If s3_enabled=true
# AUTOFLOW_S3_REGION=us-east-1

# Key prefix (folder path)
# Required: No (defaults to empty string)
# AUTOFLOW_S3_PREFIX=autoflow/

# AWS access key ID
# Required: No (can use IAM roles)
# AUTOFLOW_S3_ACCESS_KEY_ID=

# AWS secret access key
# Required: No (can use IAM roles)
# AUTOFLOW_S3_SECRET_ACCESS_KEY=

# Endpoint URL (for S3-compatible services like MinIO)
# Required: No
# AUTOFLOW_S3_ENDPOINT_URL=

# Use SSL/TLS
# Required: No (defaults to true)
# AUTOFLOW_S3_USE_SSL=true

# Signature version (s3v4, s3v2)
# Required: No (defaults to s3v4)
# AUTOFLOW_S3_SIGNATURE_VERSION=s3v4

# Max concurrent uploads
# Required: No (defaults to 10)
# AUTOFLOW_S3_MAX_CONCURRENCY=10

# --- Google Cloud Storage Settings ---

# Enable GCS
# Required: No (defaults to false)
# AUTOFLOW_GCS_ENABLED=false

# GCS bucket name
# Required: If gcs_enabled=true
# AUTOFLOW_GCS_BUCKET=autoflow-bucket

# Path to service account credentials JSON
# Required: If gcs_enabled=true
# AUTOFLOW_GCS_CREDENTIALS_PATH=/path/to/service-account.json

# Key prefix (folder path)
# Required: No (defaults to empty string)
# AUTOFLOW_GCS_PREFIX=autoflow/

# --- Azure Blob Storage Settings ---

# Enable Azure Blob
# Required: No (defaults to false)
# AUTOFLOW_AZURE_BLOB_ENABLED=false

# Azure storage account name
# Required: If azure_blob_enabled=true
# AUTOFLOW_AZURE_BLOB_ACCOUNT_NAME=mystorageaccount

# Azure storage account key
# Required: If azure_blob_enabled=true
# AUTOFLOW_AZURE_BLOB_ACCOUNT_KEY=my-account-key

# Container name
# Required: If azure_blob_enabled=true
# AUTOFLOW_AZURE_BLOB_CONTAINER=autoflow

# Key prefix (folder path)
# Required: No (defaults to empty string)
# AUTOFLOW_AZURE_BLOB_PREFIX=autoflow/

# --- MinIO Settings (S3-compatible Local) ---

# Enable MinIO
# Required: No (defaults to false)
# AUTOFLOW_MINIO_ENABLED=false

# MinIO endpoint URL
# Required: If minio_enabled=true
# AUTOFLOW_MINIO_ENDPOINT=http://localhost:9000

# Access key
# Required: If minio_enabled=true
# AUTOFLOW_MINIO_ACCESS_KEY=minioadmin

# Secret key
# Required: If minio_enabled=true
# AUTOFLOW_MINIO_SECRET_KEY=minioadmin

# Bucket name
# Required: If minio_enabled=true
# AUTOFLOW_MINIO_BUCKET=autoflow

# Use SSL/TLS
# Required: No (defaults to false)
# AUTOFLOW_MINIO_USE_SSL=false

# ============================================
# COMMUNICATION CONFIGURATION
# ============================================

# --- Slack Settings ---

# Enable Slack
# Required: No (defaults to false)
# AUTOFLOW_SLACK_ENABLED=false

# Slack bot token (xoxb-*)
# Required: If slack_enabled=true
# AUTOFLOW_SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack signing secret
# Required: If using Slack app
# AUTOFLOW_SLACK_SIGNING_SECRET=

# Slack channel for notifications
# Required: If slack_enabled=true
# AUTOFLOW_SLACK_CHANNEL=#autoflow-notifications

# Slack channel for approvals
# Required: No
# AUTOFLOW_SLACK_APPROVAL_CHANNEL=#autoflow-approvals

# Timeout in seconds
# Required: No (defaults to 30)
# AUTOFLOW_SLACK_TIMEOUT=30

# Enable Slack app (interactive)
# Required: No (defaults to false)
# AUTOFLOW_SLACK_APP_ENABLED=false

# App verification token
# Required: No
# AUTOFLOW_SLACK_VERIFICATION_TOKEN=

# --- Discord Settings ---

# Enable Discord
# Required: No (defaults to false)
# AUTOFLOW_DISCORD_ENABLED=false

# Discord bot token
# Required: If discord_enabled=true
# AUTOFLOW_DISCORD_BOT_TOKEN=your-discord-bot-token

# Discord channel ID for notifications
# Required: If discord_enabled=true
# AUTOFLOW_DISCORD_CHANNEL_ID=123456789012345678

# Command prefix
# Required: No (defaults to "!")
# AUTOFLOW_DISCORD_COMMAND_PREFIX=!

# --- Microsoft Teams Settings ---

# Enable Teams
# Required: No (defaults to false)
# AUTOFLOW_TEAMS_ENABLED=false

# Teams webhook URL
# Required: If teams_enabled=true
# AUTOFLOW_TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/xxx

# --- Email Settings ---

# Enable email notifications
# Required: No (defaults to false)
# AUTOFLOW_EMAIL_ENABLED=false

# SMTP host
# Required: If email_enabled=true
# AUTOFLOW_EMAIL_SMTP_HOST=smtp.gmail.com

# SMTP port
# Required: No (defaults to 587)
# AUTOFLOW_EMAIL_SMTP_PORT=587

# Use TLS
# Required: No (defaults to true)
# AUTOFLOW_EMAIL_USE_TLS=true

# Email username
# Required: If email_enabled=true
# AUTOFLOW_EMAIL_USERNAME=your-email@gmail.com

# Email password
# Required: If email_enabled=true
# AUTOFLOW_EMAIL_PASSWORD=your-app-password

# From address
# Required: If email_enabled=true
# AUTOFLOW_EMAIL_FROM=autoflow@example.com

# To addresses (comma-separated)
# Required: If email_enabled=true
# AUTOFLOW_EMAIL_TO=team@example.com,admin@example.com

# --- PagerDuty Settings ---

# Enable PagerDuty
# Required: No (defaults to false)
# AUTOFLOW_PAGERDUTY_ENABLED=false

# PagerDuty API key
# Required: If pagerduty_enabled=true
# AUTOFLOW_PAGERDUTY_API_KEY=your-api-key

# Integration key (routing key)
# Required: If pagerduty_enabled=true
# AUTOFLOW_PAGERDUTY_INTEGRATION_KEY=your-integration-key

# Severity level (critical, error, warning, info)
# Required: No (defaults to error)
# AUTOFLOW_PAGERDUTY_SEVERITY=error

# ============================================
# OBSERVABILITY & TELEMETRY
# ============================================

# Enable observability (logging, tracing, metrics)
# Required: No (defaults to true)
AUTOFLOW_OBSERVABILITY_ENABLED=true

# --- OpenTelemetry Core Settings ---

# Enable OpenTelemetry tracing
# Required: No (defaults to false)
OTEL_ENABLED=false

# Service name
# Required: If otel_enabled=true (defaults to "autoflow-engine")
OTEL_SERVICE_NAME=autoflow-engine

# Service version
# Required: No (defaults to "1.0.0")
# OTEL_SERVICE_VERSION=1.0.0

# Environment (deployment environment)
# Required: No (defaults to AUTOFLOW_ENVIRONMENT)
# OTEL_ENVIRONMENT=development

# --- OTLP Exporter Settings ---

# OTLP endpoint (traces)
# Required: If otel_enabled=true
# For local Grafana Tempo: http://localhost:4317
# For Grafana Cloud: https://otlp-gateway-prod-us-central-0.grafana.net:4317
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# OTLP headers (for authentication)
# Required: For Grafana Cloud
# Format: "Authorization=Basic <base64-encoded-creds>"
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic xxx

# OTLP protocol (grpc, http/protobuf)
# Required: No (defaults to grpc)
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# Certificate path (for TLS)
# Required: No
# OTEL_EXPORTER_OTLP_CERTIFICATE=/path/to/cert.pem

# --- Grafana Cloud Settings ---

# Grafana Cloud instance ID
# Required: For Grafana Cloud
# GRAFANA_CLOUD_INSTANCE_ID=your-instance-id

# Grafana Cloud API key
# Required: For Grafana Cloud
# GRAFANA_CLOUD_API_KEY=your-api-key

# Grafana Cloud stack URL
# Required: No (auto-detected from instance ID)
# GRAFANA_CLOUD_STACK_URL=

# --- Sampling Settings ---

# Traces sampler (always_on, always_off, traceidratio, parentbased_always_on)
# Required: No (defaults to always_on)
# OTEL_TRACES_SAMPLER=always_on

# Sampling ratio (0.0 to 1.0)
# Required: No (defaults to 1.0)
# OTEL_TRACES_SAMPLER_ARG=1.0

# --- Batch Processor Settings ---

# Batch export schedule delay (milliseconds)
# Required: No (defaults to 5000)
# OTEL_BSP_SCHEDULE_DELAY_MILLIS=5000

# Max batch size
# Required: No (defaults to 512)
# OTEL_BSP_MAX_QUEUE_SIZE=2048

# Max export batch size
# Required: No (defaults to 512)
# OTEL_BSP_MAX_EXPORT_BATCH_SIZE=512

# Export timeout (milliseconds)
# Required: No (defaults to 30000)
# OTEL_BSP_EXPORT_TIMEOUT_MILLIS=30000

# --- Resource Attributes ---

# Service namespace
# Required: No
# OTEL_RESOURCE_ATTRIBUTES=service.namespace=autoflow

# Deployment environment
# Required: No
# OTEL_DEPLOYMENT_ENVIRONMENT=development

# --- Loki Settings (Log Aggregation) ---

# Enable Loki
# Required: No (defaults to false)
# AUTOFLOW_LOKI_ENABLED=false

# Loki endpoint
# Required: If loki_enabled=true
# AUTOFLOW_LOKI_ENDPOINT=http://localhost:3100

# Loki tenant ID
# Required: No
# AUTOFLOW_LOKI_TENANT_ID=

# --- Prometheus Settings (Metrics) ---

# Enable Prometheus metrics
# Required: No (defaults to false)
# AUTOFLOW_PROMETHEUS_ENABLED=false

# Prometheus endpoint
# Required: If prometheus_enabled=true
# AUTOFLOW_PROMETHEUS_ENDPOINT=http://localhost:9090

# Metrics port
# Required: No (defaults to 9464)
# AUTOFLOW_PROMETHEUS_PORT=9464

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Required: No (defaults to INFO)
AUTOFLOW_LOG_LEVEL=INFO

# Log format: TEXT, JSON
# Required: No (defaults to TEXT)
AUTOFLOW_LOG_FORMAT=TEXT

# Log file path (empty for stdout only)
# Required: No (defaults to empty string)
# AUTOFLOW_LOG_FILE=

# Enable structured logging
# Required: No (defaults to false)
# AUTOFLOW_STRUCTURED_LOGGING=false

# Enable log rotation
# Required: No (defaults to true)
# AUTOFLOW_LOG_ROTATION=true

# Max log file size in MB
# Required: No (defaults to 10)
# AUTOFLOW_LOG_MAX_BYTES=10485760

# Number of backup files to keep
# Required: No (defaults to 5)
# AUTOFLOW_LOG_BACKUP_COUNT=5

# ============================================
# POLICY & SAFETY CONFIGURATION
# ============================================

# Maximum risk level: LOW, MEDIUM, HIGH, CRITICAL
# Required: No (defaults to MEDIUM)
AUTOFLOW_POLICY_MAX_RISK=MEDIUM

# Allowed file paths (comma-separated)
# Required: No (defaults to empty - allow all)
# AUTOFLOW_POLICY_ALLOWED_PATHS=config/,prompts/,skills/

# Blocked file paths (comma-separated)
# Required: No (defaults to empty)
# AUTOFLOW_POLICY_BLOCKED_PATHS=/etc,/var,/usr

# Require human approval for changes
# Required: No (defaults to false)
# AUTOFLOW_POLICY_REQUIRE_APPROVAL=false

# Enable dry-run mode (no actual changes)
# Required: No (defaults to false in production, true in development)
# AUTOFLOW_POLICY_DRY_RUN=false

# Auto-approve safe changes
# Required: No (defaults to true)
# AUTOFLOW_POLICY_AUTO_APPROVE_SAFE=true

# Maximum budget per improvement (USD)
# Required: No (defaults to 0 - unlimited)
# AUTOFLOW_POLICY_MAX_BUDGET=0

# ============================================
# PERFORMANCE & SCALING
# ============================================

# Batch size for processing
# Required: No (defaults to 100)
AUTOFLOW_BATCH_SIZE=100

# Number of worker threads
# Required: No (defaults to CPU count)
# AUTOFLOW_WORKER_THREADS=4

# Max concurrent operations
# Required: No (defaults to 10)
# AUTOFLOW_MAX_CONCURRENT=10

# Operation timeout in seconds
# Required: No (defaults to 300)
# AUTOFLOW_TIMEOUT=300

# Retry attempts
# Required: No (defaults to 3)
# AUTOFLOW_MAX_RETRIES=3

# Retry delay in seconds
# Required: No (defaults to 1)
# AUTOFLOW_RETRY_DELAY=1

# Cache enabled
# Required: No (defaults to true)
# AUTOFLOW_CACHE_ENABLED=true

# Cache TTL in seconds
# Required: No (defaults to 3600)
# AUTOFLOW_CACHE_TTL=3600

# ============================================
# SECURITY & AUTHENTICATION
# ============================================

# Enable SSL/TLS for connections
# Required: No (defaults to true in production)
# AUTOFLOW_SSL_ENABLED=true

# SSL certificate path
# Required: No
# AUTOFLOW_SSL_CERT_PATH=/path/to/cert.pem

# SSL key path
# Required: No
# AUTOFLOW_SSL_KEY_PATH=/path/to/key.pem

# SSL CA certificate path
# Required: No
# AUTOFLOW_SSL_CA_PATH=/path/to/ca.pem

# API key for AutoFlow API
# Required: No
# AUTOFLOW_API_KEY=your-api-key

# Enable API authentication
# Required: No (defaults to true if api_key is set)
# AUTOFLOW_API_AUTH_ENABLED=false

# Allowed IP addresses (comma-separated)
# Required: No (defaults to empty - allow all)
# AUTOFLOW_ALLOWED_IPS=127.0.0.1,10.0.0.0/8

# Enable rate limiting
# Required: No (defaults to false)
# AUTOFLOW_RATE_LIMIT_ENABLED=false

# Rate limit (requests per minute)
# Required: If rate_limit_enabled=true
# AUTOFLOW_RATE_LIMIT=60

# ============================================
# AI/ML MODEL CONFIGURATION
# ============================================

# --- OpenAI Settings ---

# OpenAI API key
# Required: If using OpenAI models
# OPENAI_API_KEY=sk-your-openai-api-key

# OpenAI organization ID
# Required: No
# OPENAI_ORGANIZATION=org-your-org-id

# OpenAI base URL (for Azure OpenAI or proxy)
# Required: No
# OPENAI_BASE_URL=https://api.openai.com/v1

# Default model
# Required: No (defaults to gpt-4)
# OPENAI_MODEL=gpt-4

# Max tokens
# Required: No (defaults to 4096)
# OPENAI_MAX_TOKENS=4096

# Temperature (0.0 to 2.0)
# Required: No (defaults to 0.7)
# OPENAI_TEMPERATURE=0.7

# --- Anthropic Claude Settings ---

# Anthropic API key
# Required: If using Claude models
# ANTHROPIC_API_KEY=sk-ant-your-api-key

# Anthropic base URL
# Required: No
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Default model
# Required: No (defaults to claude-3-opus-20240229)
# ANTHROPIC_MODEL=claude-3-opus-20240229

# Max tokens
# Required: No (defaults to 4096)
# ANTHROPIC_MAX_TOKENS=4096

# Temperature (0.0 to 1.0)
# Required: No (defaults to 0.7)
# ANTHROPIC_TEMPERATURE=0.7

# --- Hugging Face Settings ---

# Hugging Face API key
# Required: If using Hugging Face models
# HUGGINGFACE_API_KEY=your-huggingface-api-key

# Model ID
# Required: If using Hugging Face
# HUGGINGFACE_MODEL=gpt2

# --- Local Model Settings ---

# Local model path
# Required: If using local models
# AUTOFLOW_LOCAL_MODEL_PATH=/path/to/model

# Model device (cpu, cuda, mps)
# Required: No (defaults to cpu)
# AUTOFLOW_MODEL_DEVICE=cpu

# Model precision (float32, float16, int8)
# Required: No (defaults to float32)
# AUTOFLOW_MODEL_PRECISION=float32

# ============================================
# GRAPH CONFIGURATION
# ============================================

# Max graph depth for traversal
# Required: No (defaults to 10)
# AUTOFLOW_MAX_GRAPH_DEPTH=10

# Max nodes to process
# Required: No (defaults to 1000)
# AUTOFLOW_MAX_NODES=1000

# Graph pruning threshold
# Required: No (defaults to 0.1)
# AUTOFLOW_PRUNE_THRESHOLD=0.1

# Enable graph caching
# Required: No (defaults to true)
# AUTOFLOW_GRAPH_CACHE_ENABLED=true

# ============================================
# ADVANCED OPTIONS
# ============================================

# Enable profiling
# Required: No (defaults to false)
# AUTOFLOW_PROFILING_ENABLED=false

# Profiling output directory
# Required: If profiling_enabled=true
# AUTOFLOW_PROFILING_OUTPUT=./profiling

# Enable feature flags
# Required: No (defaults to false)
# AUTOFLOW_FEATURE_FLAGS_ENABLED=false

# Feature flags configuration (JSON)
# Required: No
# AUTOFLOW_FEATURE_FLAGS={"new_feature": true, "experimental": false}

# Enable metrics collection
# Required: No (defaults to true)
# AUTOFLOW_METRICS_ENABLED=true

# Metrics export interval (seconds)
# Required: No (defaults to 60)
# AUTOFLOW_METRICS_INTERVAL=60

# ============================================
# NOTES
# ============================================
# 1. Variables marked as "Required: Yes" are necessary for basic operation
# 2. Variables marked as "Required: If X" are necessary when that feature is enabled
# 3. Variables marked as "Required: No" have sensible defaults
# 4. Secret values (API keys, passwords) should never be committed to git
# 5. Use .env.local for local overrides (not committed)
# 6. Use .env.production for production-specific settings (not committed)
# 7. Use .env.development for development-specific settings (not committed)
